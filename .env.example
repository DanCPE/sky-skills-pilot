# ─────────────────────────────────────────────
# Sky Skills — Environment Variables Template
# Copy this file and fill in real values.
#
# Local dev  →  copy to .env.local
# Vercel     →  set each variable in the Vercel
#               dashboard, scoped to the correct
#               environment (see notes below).
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
# Supabase PostgreSQL connection string.
# Vercel scope:
#   Production → production Supabase project
#   Preview    → staging Supabase project
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Optional salt used for hashing client IP in analytics.
# Change this for each environment.
ANALYTICS_IP_SALT="replace-with-random-secret"

# Enable verbose analytics debug logs in server console.
# Set to "true" temporarily while troubleshooting.
ANALYTICS_DEBUG="false"

# ── App ───────────────────────────────────────
# Public base URL of the app (used for absolute URLs / redirects).
# Vercel scope:
#   Production → https://your-domain.com
#   Preview    → https://your-project-git-branch.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Google-only account login ─────────────────
# Create an OAuth client in Google Cloud Console.
# Authorized redirect URI:
#   http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Optional override when NEXT_PUBLIC_APP_URL is not the public callback host.
# GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# ── Subscription payments ────────────────────
# Bank details shown on the subscription page.
MANUAL_PAYMENT_BANK_NAME="Krungthai Bank"
MANUAL_PAYMENT_ACCOUNT_NAME=""
MANUAL_PAYMENT_ACCOUNT_NUMBER=""
MANUAL_PAYMENT_PROMPTPAY_ID=""
MANUAL_PAYMENT_CURRENCY="THB"

# Slip2Go automatic slip verification.
# Set the endpoint from Slip2Go's API Connect dashboard/docs.
SLIP2GO_API_URL=""
SLIP2GO_API_KEY=""
SLIP2GO_AUTH_HEADER="Authorization"
SLIP2GO_AUTH_SCHEME="Bearer"
SLIP2GO_METHOD="POST"
# Supported request modes:
#   multipart → sends QR payload plus uploaded file
#   json      → sends QR payload, or base64 file when QR is unavailable
SLIP2GO_REQUEST_MODE="multipart"
SLIP2GO_QR_FIELD="qrCode"
SLIP2GO_IMAGE_FIELD="image"
SLIP2GO_BASE64_FIELD="image"
# Optional emergency fallback. When true, slips are queued for manual approval
# if Slip2Go is not configured; when false, uploads return 503.
SLIP2GO_ALLOW_MANUAL_FALLBACK="false"

# ── Python backend (optional) ─────────────────
# Only needed if self-hosting the FastAPI server outside Vercel.
# Leave blank when deploying on Vercel (handled by rewrites in next.config.ts).
# PYTHON_API_URL=""
