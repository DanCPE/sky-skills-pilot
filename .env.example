# ─────────────────────────────────────────────
# Sky Skills — Environment Variables Template
# Copy this file and fill in real values.
#
# Local dev  →  copy to .env.local
# Vercel     →  set each variable in the Vercel
#               dashboard, scoped to the correct
#               environment (see notes below).
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
# Supabase PostgreSQL connection string.
# Vercel scope:
#   Production → production Supabase project
#   Preview    → staging Supabase project
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# ── App ───────────────────────────────────────
# Public base URL of the app (used for absolute URLs / redirects).
# Vercel scope:
#   Production → https://your-domain.com
#   Preview    → https://your-project-git-branch.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Auth (NextAuth.js) ────────────────────────
# Random secret for signing JWTs — generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"

# Google OAuth credentials.
# Create at: https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── Python backend (optional) ─────────────────
# Only needed if self-hosting the FastAPI server outside Vercel.
# Leave blank when deploying on Vercel (handled by rewrites in next.config.ts).
# PYTHON_API_URL=""
